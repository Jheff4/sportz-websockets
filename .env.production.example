# =============================================================================
# .env.production.example — Production environment TEMPLATE
# =============================================================================
# This file IS committed to git — it is a safe template with no real secrets.
#
# To use it:
#   cp .env.production.example .env.production
#   # then fill in real values in .env.production
#
# .env.production is git-ignored and must NEVER be committed.
# In CI/CD pipelines, inject these as environment variables directly
# (GitHub Actions secrets, Railway variables, Fly.io secrets, etc.)
# =============================================================================

NODE_ENV=production
PORT=8000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Your Neon Cloud connection string.
# Neon Console → Project → Connect → Connection string (pooled recommended)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon Cloud issues valid TLS certificates — keep this true (or just leave it unset).
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ── Application ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (your deployed frontend URL)
CORS_ORIGIN=https://your-frontend-domain.com

# Arcjet production key → https://app.arcjet.com
ARCJET_KEY=ajkey_your_production_key_here
ARCJET_MODE=LIVE

API_URL=https://your-api-domain.com
